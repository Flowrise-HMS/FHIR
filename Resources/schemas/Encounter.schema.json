{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": ["resourceType"],
    "properties": {
        "resourceType": {
            "type": "string",
            "const": "Encounter"
        },
        "id": {
            "type": "string",
            "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
        },
        "identifier": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "system": { "type": "string" },
                    "value": { "type": "string" }
                }
            }
        },
        "status": {
            "type": "string",
            "enum": ["planned", "in-progress", "on-hold", "discharged", "completed", "cancelled", "discontinued", "entered-in-error", "unknown"]
        },
        "class": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "coding": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "system": { "type": "string" },
                                "code": { "type": "string" },
                                "display": { "type": "string" }
                            }
                        }
                    },
                    "text": { "type": "string" }
                }
            }
        },
        "priority": {
            "type": "object",
            "properties": {
                "coding": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "system": { "type": "string" },
                            "code": { "type": "string" },
                            "display": { "type": "string" }
                        }
                    }
                }
            }
        },
        "subject": {
            "type": "object",
            "properties": {
                "reference": { "type": "string", "pattern": "^Patient/" }
            }
        },
        "serviceProvider": {
            "type": "object",
            "properties": {
                "reference": { "type": "string", "pattern": "^Organization/" }
            }
        },
        "serviceType": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "reference": {
                        "type": "object",
                        "properties": {
                            "reference": { "type": "string" }
                        }
                    }
                }
            }
        },
        "actualPeriod": {
            "type": "object",
            "properties": {
                "start": { "type": "string" },
                "end": { "type": "string" }
            }
        },
        "location": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "location": {
                        "type": "object",
                        "properties": {
                            "reference": { "type": "string", "pattern": "^Location/" }
                        }
                    }
                }
            }
        },
        "participant": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "type": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "coding": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "system": { "type": "string" },
                                            "code": { "type": "string" },
                                            "display": { "type": "string" }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "actor": {
                        "type": "object",
                        "properties": {
                            "reference": { "type": "string" },
                            "display": { "type": "string" }
                        }
                    },
                    "period": {
                        "type": "object",
                        "properties": {
                            "start": { "type": "string" },
                            "end": { "type": "string" }
                        }
                    }
                }
            }
        },
        "reason": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "value": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "concept": {
                                    "type": "object",
                                    "properties": {
                                        "text": { "type": "string" }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "admission": {
            "type": "object",
            "properties": {
                "dischargeDisposition": {
                    "type": "object",
                    "properties": {
                        "coding": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "system": { "type": "string" },
                                    "code": { "type": "string" },
                                    "display": { "type": "string" }
                                }
                            }
                        }
                    }
                },
                "destination": {
                    "type": "object",
                    "properties": {
                        "reference": { "type": "string" }
                    }
                }
            }
        }
    },
    "anyOf": [
        { "required": ["status", "subject"] }
    ]
}
