{
    "$schema": "http://json-schema.org/draft-06/schema#",
    "id": "http://hl7.org/fhir/JsonSchema/AppointmentResponse",
    "description": "FHIR R5 AppointmentResponse resource (standalone subset for FlowRise HMS)",
    "type": "object",
    "required": ["resourceType", "appointment", "participantStatus"],
    "properties": {
        "resourceType": { "type": "string", "enum": ["AppointmentResponse"] },
        "id": { "type": "string" },
        "appointment": { "type": "object" },
        "start": { "type": "string" },
        "end": { "type": "string" },
        "participantType": { "type": "array", "items": { "type": "object" } },
        "actor": { "type": "object" },
        "participantStatus": { "type": "string", "enum": ["accepted", "declined", "tentative", "needs-action"] },
        "comment": { "type": "string" }
    }
}
