{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": ["resourceType"],
    "properties": {
        "resourceType": {
            "type": "string",
            "const": "Condition"
        },
        "id": {
            "type": "string",
            "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
        },
        "clinicalStatus": {
            "type": "object",
            "properties": {
                "coding": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "system": { "type": "string" },
                            "code": {
                                "type": "string",
                                "enum": ["active", "recurrence", "relapse", "inactive", "remission", "resolved"]
                            }
                        }
                    }
                }
            }
        },
        "verificationStatus": {
            "type": "object",
            "properties": {
                "coding": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "system": { "type": "string" },
                            "code": {
                                "type": "string",
                                "enum": ["unconfirmed", "provisional", "differential", "confirmed", "refuted", "entered-in-error"]
                            }
                        }
                    }
                }
            }
        },
        "category": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "coding": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "system": { "type": "string" },
                                "code": { "type": "string" }
                            }
                        }
                    }
                }
            }
        },
        "code": {
            "type": "object",
            "properties": {
                "coding": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "system": { "type": "string" },
                            "code": { "type": "string" },
                            "display": { "type": "string" }
                        }
                    }
                },
                "text": { "type": "string" }
            }
        },
        "subject": {
            "type": "object",
            "properties": {
                "reference": { "type": "string", "pattern": "^Patient/" }
            }
        },
        "encounter": {
            "type": "object",
            "properties": {
                "reference": { "type": "string", "pattern": "^Encounter/" }
            }
        },
        "recordedDate": {
            "type": "string",
            "format": "date-time"
        },
        "note": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "text": { "type": "string" }
                }
            }
        }
    },
    "anyOf": [
        { "required": ["clinicalStatus", "subject"] }
    ]
}
