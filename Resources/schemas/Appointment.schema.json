{
    "$schema": "http://json-schema.org/draft-06/schema#",
    "id": "http://hl7.org/fhir/JsonSchema/Appointment",
    "description": "FHIR R5 Appointment resource (standalone subset for FlowRise HMS)",
    "type": "object",
    "required": ["resourceType", "status"],
    "properties": {
        "resourceType": { "type": "string", "enum": ["Appointment"] },
        "id": { "type": "string" },
        "status": { "type": "string", "enum": ["proposed", "pending", "booked", "arrived", "fulfilled", "cancelled", "noshow", "entered-in-error", "checked-in", "waitlist"] },
        "cancellationReason": { "type": "object" },
        "serviceCategory": { "type": "array", "items": { "type": "object" } },
        "serviceType": { "type": "array", "items": { "type": "object" } },
        "specialty": { "type": "array", "items": { "type": "object" } },
        "appointmentType": { "type": "object" },
        "reason": { "type": "array", "items": { "type": "object" } },
        "priority": { "type": "object" },
        "description": { "type": "string" },
        "start": { "type": "string" },
        "end": { "type": "string" },
        "minutesDuration": { "type": "integer", "minimum": 0 },
        "created": { "type": "string" },
        "note": { "type": "array", "items": { "type": "object" } },
        "subject": { "type": "object" },
        "participant": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["status"],
                "properties": {
                    "type": { "type": "array", "items": { "type": "object" } },
                    "actor": { "type": "object" },
                    "required": { "type": "boolean" },
                    "status": { "type": "string", "enum": ["accepted", "declined", "tentative", "needs-action"] }
                }
            }
        }
    }
}
